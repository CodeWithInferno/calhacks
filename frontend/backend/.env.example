# Backend (FastAPI) env. Copy to backend/.env. Only needed if your real policy
# loads checkpoints from / caches rollouts to Nebius. The stub runs without these.
# Same credential rules as the root .env: read at runtime, never sent to browser.

NEBIUS_S3_ENDPOINT=https://storage.eu-north1.nebius.cloud:443
NEBIUS_REGION=eu-north1
NEBIUS_BUCKET=my-robot-rollouts
NEBIUS_S3_FORCE_PATH_STYLE=false

# Credentials: inline...
AWS_ACCESS_KEY_ID=YOUR_NEBIUS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_NEBIUS_SECRET_ACCESS_KEY
# ...or a profile instead:
# AWS_PROFILE=nebius
