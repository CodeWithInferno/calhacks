# ============================================================================
#  Nebius Object Storage — fetch-layer configuration
# ----------------------------------------------------------------------------
#  Copy this file to `.env` and fill in real values. `.env` is gitignored and
#  is read ONLY by scripts/fetch-run.mjs (a Node process on your machine).
#  These values are NEVER bundled into the browser app.
# ============================================================================

# --- Bucket / endpoint --------------------------------------------------------
# Nebius is S3-compatible. Endpoint pattern: https://storage.<region>.nebius.cloud:443
NEBIUS_S3_ENDPOINT=https://storage.eu-north1.nebius.cloud:443
NEBIUS_REGION=eu-north1
NEBIUS_BUCKET=my-robot-rollouts

# Key prefix that runs live under, i.e. <prefix>/<run_id>/robot.urdf
# Use "" (empty) if runs sit at the bucket root.
NEBIUS_RUN_PREFIX=rollouts

# S3 addressing style. Default is virtual-hosted (false). If you hit DNS or
# TLS/SSL certificate errors against the endpoint, set this to "true" to use
# path-style addressing instead.
NEBIUS_S3_FORCE_PATH_STYLE=false

# ============================================================================
#  Credentials — choose ONE of the two options below. Never hardcode these in
#  source. They are read at runtime from the environment / AWS profile only.
# ----------------------------------------------------------------------------
#  How to create them:
#    1. Nebius console -> IAM -> Service Accounts -> create a service account.
#    2. Grant it read access (e.g. storage.viewer) on the bucket.
#    3. Create a static "Access key" for that service account. You receive an
#       Access Key ID + Secret Access Key (the secret is shown ONCE).
# ============================================================================

# --- Option 1: inline env vars (simplest) ------------------------------------
AWS_ACCESS_KEY_ID=YOUR_NEBIUS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_NEBIUS_SECRET_ACCESS_KEY

# --- Option 2: a named AWS profile (recommended for shared machines) ---------
# Instead of the two vars above, put credentials in ~/.aws/credentials under
# a [nebius] profile, then set AWS_PROFILE=nebius and leave the keys above blank.
#
#   ~/.aws/credentials:
#     [nebius]
#     aws_access_key_id = YOUR_NEBIUS_ACCESS_KEY_ID
#     aws_secret_access_key = YOUR_NEBIUS_SECRET_ACCESS_KEY
#
# AWS_PROFILE=nebius
