# --- secrets: never commit credentials ---
.env
.env.*
!.env.example
.aws/
*.pem

# --- dependencies / build ---
node_modules/
dist/

# --- python backend ---
backend/.venv/
__pycache__/
*.pyc

# --- fetched run artifacts (large binaries pulled from Nebius) ---
